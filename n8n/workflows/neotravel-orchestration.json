    {
      "parameters": {
        "jsCode": "function nodeJson(name) {\n  const n = $(name);\n  if (!n.isExecuted) return null;\n  const item = n.first();\n  return item ? item.json : null;\n}\n\nconst config = nodeJson('Config NeoTravel') ?? {};\nconst status = nodeJson('GET status');\nconst qualifier = nodeJson('POST qualifier');\nconst calculer = nodeJson('POST calculer-devis');\nconst generer = nodeJson('POST generer-devis');\nconst relance = nodeJson('POST relance');\nconst incomplete = nodeJson('Demande incomplète');\nconst isDemo = $('▶ Démo jury').isExecuted;\n\nreturn [{\n  json: {\n    execution_summary: {\n      at: new Date().toISOString(),\n      service: 'neotravel-orchestration',\n      mode: isDemo ? 'demo_jury' : 'schedule_relances',\n      app_url: config.app_url,\n      api_reachable: status?.ok === true || status?.body?.ok === true,\n      pending_relances: status?.pending_relances ?? status?.body?.pending_relances ?? null,\n      qualifier: qualifier ? {\n        demande_id: qualifier.demande_id,\n        pret_pour_devis: qualifier.pret_pour_devis,\n        score: qualifier.score_completude,\n        error: qualifier.error ?? null,\n        missing: qualifier.missing ?? qualifier.champs_manquants ?? null\n      } : null,\n      incomplete_message: incomplete?.message ?? null,\n      calcul: calculer?.prix_ttc ? { prix_ttc: calculer.prix_ttc, prix_ht: calculer.prix_ht } : (calculer?.erreur ? { error: calculer.erreur } : null),\n      devis: generer?.devis_id ? {\n        devis_id: generer.devis_id,\n        prix_ttc: generer.prix_ttc,\n        email_sent: generer.email_sent\n      } : null,\n      relances: {\n        ok: relance?.ok ?? null,\n        traitees: relance?.traitees ?? 0\n      }\n    }\n  }\n}];"
      },
      "id": "code-summary",
      "name": "Résumé orchestration",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2400, 180]
    }
