    {
      "parameters": {
        "jsCode": "function nodeJson(name) {\n  const n = $(name);\n  if (!n.isExecuted) return null;\n  const item = n.first();\n  return item ? item.json : null;\n}\n\nconst input = $input.first().json;\nconst config = nodeJson('Config NeoTravel') ?? {};\nconst status = nodeJson('GET status');\nconst post = nodeJson('POST relance');\nconst statusBody = status?.body ?? status;\n\nreturn [{\n  json: {\n    execution_summary: {\n      at: new Date().toISOString(),\n      service: 'neotravel-relances',\n      status: input.status || 'unknown',\n      message: input.message,\n      traitees: input.traitees ?? post?.traitees ?? 0,\n      ok: input.ok ?? post?.ok ?? null,\n      app_url: config.app_url,\n      api_base: config.api_base,\n      storage_backend: statusBody?.storage_backend ?? null,\n      pending_relances: statusBody?.pending_relances ?? null,\n      api_reachable: statusBody?.ok === true,\n      post_ok: post?.ok ?? null\n    }\n  }\n}];"
      },
      "id": "code-summary",
      "name": "Résumé exécution",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2200, 0]
    }
