# LLM — Option A (assistant conversationnel)

# --- Production Vercel (IA cloud) ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Développement local (IA locale) ---
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_MAX_TOKENS=512

# Auto (si LLM_PROVIDER non défini) : Ollama si joignable, sinon OpenAI si clé, sinon mode secours

# App
DEMO_MODE=true
WEBHOOK_SECRET=neotravel-dev-secret

# Airtable — persistance sur Vercel (optionnel, fallback fichier local sinon)
# 1. Créer une base sur https://airtable.com (voir docs/airtable-setup.md)
# 2. Créer un token : https://airtable.com/create/tokens (scopes data.records:read + write)
# 3. Copier l'ID de la base (appXXXXXXXX) depuis l'URL ou les paramètres API
# AIRTABLE_API_KEY=patXXXXXXXX
# AIRTABLE_BASE_ID=appXXXXXXXX
# Noms des tables (optionnel — défaut : Demandes, Devis, Relances, Logs)
# AIRTABLE_TABLE_DEMANDES=Demandes
# AIRTABLE_TABLE_DEVIS=Devis
# AIRTABLE_TABLE_RELANCES=Relances
# AIRTABLE_TABLE_LOGS=Logs
# Alias historique (équivaut à AIRTABLE_TABLE_DEMANDES)
# AIRTABLE_TABLE=Demandes
# URL publique (tunnel Cloudflare, Vercel…) pour les liens dans les emails
APP_BASE_URL=http://localhost:3000

# Email — option 1 : Gmail (le plus rapide si tu as déjà Google)
# 1. https://myaccount.google.com/apppasswords → créer un mot de passe "NeoTravel"
# 2. Coller ci-dessous :
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=ton.email@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# EMAIL_FROM=NeoTravel <ton.email@gmail.com>

# Email — option 2 : Brevo (gratuit, 300 mails/jour — bien pour la soutenance)
# 1. https://www.brevo.com → compte gratuit
# 2. Paramètres → SMTP & API → générer une clé SMTP
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=ton.email@inscription-brevo.com
# SMTP_PASS=cle_smtp_brevo
# EMAIL_FROM=NeoTravel <ton.email@inscription-brevo.com>

# Email — option 3 : Resend (API, pas SMTP)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=NeoTravel <onboarding@resend.dev>

# Sans RESEND ni SMTP : emails simulés dans la console (tests E2E OK)

# Déploiement Vercel (local uniquement — ne pas ajouter dans le dashboard Vercel)
# Créer un token : https://vercel.com/account/tokens
# VERCEL_TOKEN=vercel_xxxxxxxx
# VERCEL_SCOPE=slug-equipe-vercel

# Variables à configurer dans Vercel → Project → Settings → Environment Variables :
# - APP_BASE_URL=https://votre-projet.vercel.app
# - Option A prod : LLM_PROVIDER=openai + OPENAI_API_KEY (+ OPENAI_MODEL optionnel)
# - Option A local : Ollama (OLLAMA_* — ne pas utiliser sur Vercel)
# - Mode secours sans LLM : DEMO_MODE=true (chat bascule sur /api/chat/demo)
# - SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, EMAIL_FROM (Brevo/Gmail)
# - WEBHOOK_SECRET (relances webhook)
# - Optionnel : RESEND_API_KEY à la place de SMTP
# Voir docs/DEPLOY-VERCEL.md
